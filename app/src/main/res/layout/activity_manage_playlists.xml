<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="?attr/android:colorBackground"
    tools:context=".ManagePlaylistsActivity">

    <!-- App Title -->
    <TextView
        android:id="@+id/tvTitlePlayListsManagement"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Playlist Management"
        android:textAppearance="?attr/textAppearanceHeadlineMedium"
        android:textColor="?attr/colorOnBackground"
        android:layout_marginBottom="48dp"/>

    <!-- Pick Music Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddMusic"
        style="@style/Widget.Material3.Button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="?attr/colorPrimary"
        android:icon="@android:drawable/stat_sys_upload"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:layout_marginBottom="5dp"
        android:text="@string/add_songs_to_library"
        android:textColor="?attr/colorOnPrimary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClearLibrary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/clear_library"/>

    <!-- Optional: Status / instructions -->
    <TextView
        android:id="@+id/tvInstructions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Playlist XXX Total Songs"
        android:textColor="?attr/colorOnBackground"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="12dp"
        android:gravity="center"/>

    <TextView
        android:id="@+id/txtTrackTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_track_playing"
        android:textSize="18sp"
        android:textStyle="bold"
        android:padding="8dp"/>

    <SeekBar
        android:id="@+id/seekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="1000"/>

    <TextView
        android:id="@+id/txtTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/player_time_zero"
        android:padding="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrevious"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            app:iconSize="60dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_skip_previous"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:cornerRadius="5dp"
            android:contentDescription="@string/previous"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlayPause"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            app:iconSize="60dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_play"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:cornerRadius="5dp"
            android:contentDescription="@string/play"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            app:iconSize="60dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_skip_next"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:cornerRadius="5dp"
            android:contentDescription="@string/next"/>

        <View
            android:layout_width="2dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="12dp"
            android:background="?attr/colorOutlineVariant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStop"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            app:iconSize="60dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_stop"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:cornerRadius="5dp"
            android:contentDescription="@string/stop"/>

    </LinearLayout>

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchPureRandom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:layout_marginBottom="10dp"
        android:text="True Random Madness!!!!"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:scaleX="1.3"
        android:scaleY="1.3"
        app:thumbIcon="@drawable/ic_dice_d20"
        app:thumbIconSize="48dp"
        app:thumbIconTint="@null"
        app:trackDecorationTint="@android:color/holo_orange_dark" />

    <!-- Volume Control Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_lock_silent_mode"
            app:tint="?attr/colorOnSurface" />

        <SeekBar
            android:id="@+id/volumeSeekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="100"
            android:progress="25" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            app:tint="?attr/colorOnSurface" />
    </LinearLayout>

</LinearLayout>