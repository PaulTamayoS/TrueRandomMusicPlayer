<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="?attr/android:colorBackground"
    tools:context=".ManagePlaylistsActivity">

    <TextView
        android:id="@+id/tvTitlePlayListsManagement"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Playlist Management"
        android:textAppearance="?attr/textAppearanceHeadlineMedium"
        android:textColor="?attr/colorOnBackground"
        android:layout_marginBottom="48dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Current Playlist : "
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textColor="?attr/colorOnBackground" />

    <EditText
        android:id="@+id/editTextPlaylistName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="text"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="25dp"
        android:text="Enter Name" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddMusic"
        style="@style/Widget.Material3.Button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="?attr/colorPrimary"
        android:icon="@android:drawable/stat_sys_upload"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:layout_marginBottom="5dp"
        android:text="@string/add_songs_to_library"
        android:textColor="?attr/colorOnPrimary" />

    <TextView
        android:id="@+id/tvInstructions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Playlist XXX Total Songs"
        android:textColor="?attr/colorOnBackground"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="12dp"
        android:gravity="center"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClearLibrary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/clear_library"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="80dp"
        android:weightSum="5"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:text="Cancel Changes"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:layout_weight="2"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="5dp"
            android:contentDescription="Cancel Changes"/>

        <View
            android:layout_width="2dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="12dp"
            android:layout_weight="1"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:text="Save Changes"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:layout_weight="2"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="5dp"
            android:contentDescription="Save Changes"/>

    </LinearLayout>

</LinearLayout>